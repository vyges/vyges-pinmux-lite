{
  "$schema": "https://vyges.com/schema/v1/vyges-metadata.schema.json",
  "name": "vyges-pinmux-lite",
  "version": "0.1.0",
  "description": "Lightweight pin multiplexer with native TL-UL slave interface. Per-pin function select (4 functions), output enable, pull-up/pull-down control, 2-FF input synchronizer. For IO pad ring configuration.",
  "category": "infrastructure",
  "license": "Apache-2.0",
  "owner": "Vyges Inc.",
  "maturity": "development",
  "created": "2026-03-28T15:24:56Z",
